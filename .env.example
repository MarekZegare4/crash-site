# Backend – copy to .env and fill in real values

# JWT secret used to sign auth tokens.
# Generate a strong random value, e.g.: openssl rand -hex 32
AUTH_JWT_SECRET=change-this-in-production

# Comma-separated list of "provider:providerUserId" pairs that receive the admin role.
# Example: ADMIN_SOCIAL_IDS=google:1234567890,github:987654
ADMIN_SOCIAL_IDS=

# Port the backend listens on (default: 4000)
PORT=4000

# Allowed origin for CORS – set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Public base URL of this backend – used to build OAuth callback URLs
OAUTH_CALLBACK_BASE=http://localhost:4000

# URL of the frontend – users are redirected here after OAuth with ?token=JWT
FRONTEND_URL=http://localhost:5173

# Google OAuth – create credentials at https://console.cloud.google.com/
# Authorized redirect URI: ${OAUTH_CALLBACK_BASE}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth – create app at https://github.com/settings/developers
# Authorized callback URL: ${OAUTH_CALLBACK_BASE}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend API URL – baked into the JS bundle at build time (used by docker-compose)
# Set to the public URL of the backend API, e.g. https://api.example.com/api
VITE_API_URL=http://localhost:4000/api
