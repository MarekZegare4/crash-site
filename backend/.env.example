# Server
PORT=4000
NODE_ENV=development

# Security — generate with: openssl rand -hex 64
AUTH_JWT_SECRET=change_me_to_a_long_random_secret

# CORS / frontend
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Public site URL used when generating share links (optional)
# If set, overrides the value configurable in the admin panel
# SITE_URL=https://example.com

# OAuth callback base (must match the redirect URI registered with each provider)
OAUTH_CALLBACK_BASE=http://localhost:3001

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated list of OAuth provider user IDs that get admin role on first login
# Format: provider:providerUserId  e.g. github:123456,google:000000
# ADMIN_SOCIAL_IDS=github:123456
